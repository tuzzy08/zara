POSTGRES_DB=zara
POSTGRES_USER=zara
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://zara:replace-with-a-long-random-database-password@postgres:5432/zara

MINIO_ROOT_USER=zara-minio-root
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-root-password
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=zara-minio-root
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-root-password
OBJECT_STORAGE_FORCE_PATH_STYLE=true
RECORDINGS_BUCKET=zara-recordings
ASSETS_BUCKET=zara-assets

API_PUBLIC_URL=https://api.example.com
APP_PUBLIC_URL=https://app.example.com
ADMIN_PUBLIC_URL=https://admin.example.com
ZARA_TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
SANDBOX_TRANSPORT_TOKEN_SECRET=replace-with-at-least-32-random-characters

LOG_LEVEL=info
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=zara-production
