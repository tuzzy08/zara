{
  "name": "@zara/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:raw && node ../../scripts/patch-esm-extensions.mjs dist-js",
    "build:raw": "tsc -p tsconfig.json",
    "dev": "npm run build --workspace @zara/core && npm run build:raw && npm run dev:raw",
    "dev:raw": "concurrently -k -n tsc,api -c cyan,blue \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"dotenv -e ../../.env.example -e ../../.env -- tsx watch dist-js/main.js\"",
    "start": "npm run build --workspace @zara/core && npm run build:raw && npm run start:raw",
    "start:raw": "dotenv -e ../../.env.example -e ../../.env -- tsx dist-js/main.js",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.47.1",
    "@zara/core": "file:../../packages/core",
    "better-auth": "^1.6.10",
    "drizzle-orm": "^0.45.2",
    "langsmith": "^0.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2"
  }
}
