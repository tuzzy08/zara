# Copy this file to `.env` for local development. Never commit real secrets.
NODE_ENV=development
ZARA_ENV=local
PORT=4010
LOG_LEVEL=debug
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zara
BETTER_AUTH_URL=http://127.0.0.1:4010
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
# Live sandbox provider keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHEAP_MODEL=gpt-4.1-mini
OPENAI_STANDARD_MODEL=gpt-4.1
OPENAI_SOTA_MODEL=gpt-4.1
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_API_VERSION=2026-03-01
# Optional telephony hardening overrides
TELEPHONY_CREDENTIAL_MASTER_KEY=
TELEPHONY_CREDENTIAL_KEY_VERSION=1
TELEPHONY_CREDENTIAL_LEGACY_KEYS=
ZARA_TELEPHONY_HEARTBEAT_INTERVAL_MS=0
